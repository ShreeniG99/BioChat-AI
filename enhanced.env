# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Elasticsearch
ES_HOST=http://biorag-elasticsearch:9200
ES_USER=elastic
ES_PASSWORD=Dnu-k*qhaH-6SzY1G+AK
ES_INDEX_NAME=biomedical_docs
ES_TIMEOUT=30
ES_MAX_RETRIES=3

# Database
DATABASE_PATH=./data/users.db

# PubMed API
PUBMED_API_KEY=a097711909f43e38dc1fd18bc664bbc75508
PUBMED_EMAIL=shreenig99@gmail.com
PUBMED_MAX_RESULTS=400

# Models
BIOBERT_MODEL=dmis-lab/biobert-v1.1
BIOGPT_MODEL=microsoft/biogpt
EMBEDDING_DIMENSION=768

# RAG Settings
RAG_MAX_CONTEXT_LENGTH=4000
RAG_MIN_ANSWER_LENGTH=160
RAG_TARGET_SENTENCES=8
RAG_MAX_CITATIONS=10
RAG_DENSE_WEIGHT=0.6
RAG_SPARSE_WEIGHT=0.4

# Citation validation
CITATION_SIMILARITY_THRESHOLD=0.3
CITATION_VALIDATION_ENABLED=true
CITATION_QUALITY_ASSESSMENT=true

# Requests
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=60
GENERATION_MAX_TOKENS=400
GENERATION_TEMPERATURE=0.5

# Evaluation
EVALUATION_ENABLED=true
BENCHMARK_COMPARISON=true
PERFORMANCE_CURVES=true
EVALUATION_SAVE_RESULTS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/biorag.log
SECRET_KEY=JqGkAPpz595lw1E02MRNbzuPy6iU6bD-hfmOTkjQICG1y5MaZIvVCX147kJyq4Ky5Ov7GAoTLOOT9t2v8lcMfA
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Features
HYBRID_SEARCH_ENABLED=true
PARAGRAPH_GENERATION_ENABLED=true
COMPREHENSIVE_EVALUATION_ENABLED=true
BENCHMARK_COMPARISON_ENABLED=true

# Debug
DEBUG=true
RELOAD=true
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://127.0.0.1:3000"]
